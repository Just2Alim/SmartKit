# SmartKit local/staging configuration
#
# Copy this file to .env for local notes, but pass values to Flutter with
# --dart-define or --dart-define-from-file when running the app.

# Supabase/PostgreSQL
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=sb_publishable_or_legacy_anon_key

# Supabase Edge Functions base URL for AI and server workflows.
SMARTKIT_API_BASE_URL=http://localhost:8787

# Server-side/local-only. Never expose these in Flutter builds.
# Hosted Supabase Edge Functions receive SUPABASE_* runtime secrets automatically.
SUPABASE_SERVICE_ROLE_KEY=sb_secret_or_service_role_key
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/postgres
OLLAMA_BASE_URL=https://your-public-ollama-or-llm-gateway.example.com
OLLAMA_MODEL=qwen3:latest
OLLAMA_PROXY_TOKEN=change_me_when_exposing_scripts_ollama_proxy
OLLAMA_API_KEY=change_me_to_match_ollama_proxy_token_for_edge_functions
